# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.fuse_hidden*
.Trash-*

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.cursor/

# Claude Code local state
.claude/
CLAUDE.local.md

# Skill source trees live inside the repo as plain directories (e.g. aivalue/avp-pov-builder/).
# .skill archives are auto-generated by the pre-commit hook and also tracked for GitHub downloads.
# Only these scratch/working paths are excluded:
scratch/
work/
tmp/
unpacked/
*.skill.unpacked/

# Build / packaging junk that can sneak into a re-zipped .skill
__MACOSX/

# Python (skills may ship helper scripts; ignore their caches if unpacked)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node (same rationale)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs / env
*.log
.env
.env.local
.env.*.local
